{
  "name": "recastjs",
  "version": "0.3.0",
  "description": "A wrapper for the RecastDetour navigation library for node and the browser",
  "main": "./lib/recast.js",
  "types": "./src/recast.d.ts",
  "exports": {
    ".": {
      "types": "./src/recast.d.ts",
      "import": "./lib/recast.mjs",
      "require": "./lib/recast.js"
    }
  },
  "bin": {
    "recast": "./bin/recast.js"
  },
  "scripts": {
    "build": "make build",
    "build:esm": "make build-esm",
    "build:debug": "make build-debug",
    "docs": "make docs",
    "lint": "eslint src/ bin/ tests/unit/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:vincent/recast.js.git"
  },
  "keywords": [
    "navigation",
    "mesh",
    "3D",
    "emscripten",
    "pathfinding"
  ],
  "author": "Vincent Lark <vincent.lark@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vincent/recast.js/issues"
  },
  "homepage": "https://github.com/vincent/recast.js",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "three": "^0.183.2",
    "typedoc": "^0.28.18",
    "typedoc-github-theme": "^0.4.0",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "minimist": "^1.2.8"
  }
}
